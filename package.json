{
  "name": "raw-editor",
  "version": "0.9.4",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:phone": "HTTPS=1 vite",
    "dev:server": "node --watch server/app.js",
    "build": "vite build",
    "icons": "python3 scripts/generate-icons.py",
    "start": "NODE_ENV=production node server/app.js",
    "typecheck": "tsc -p jsconfig.json && tsc -p jsconfig.web.json",
    "prelint": "npm run typecheck",
    "lint": "eslint . --fix",
    "test": "node --test 'server/**/__tests__/*.test.js' 'src/**/__tests__/*.test.js'",
    "prepare": "husky"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.4",
    "hono": "^4.12.25",
    "libraw-wasm": "^1.3.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.9.2",
    "@vitejs/plugin-basic-ssl": "^2.3.0",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "prettier": "^3.8.4",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vite-plugin-pwa": "^1.3.0"
  }
}
